# ============================================================
# Sigweb — Variables d'environnement
# Copier ce fichier en .env.local et renseigner les valeurs
# Ne jamais committer .env.local dans git
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Site (domaine de production) ─────────────────────────────
# À renseigner avant déploiement Vercel
NEXT_PUBLIC_SITE_URL=https://votre-domaine.fr

# ── Contact (StickyContactBar mobile) ────────────────────────
NEXT_PUBLIC_PHONE=+33600000000
NEXT_PUBLIC_PHONE_DISPLAY=06 00 00 00 00

# ── Resend (notifications email formulaire contact) ───────────
# Créer un compte sur resend.com et vérifier votre domaine
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_TO_EMAIL=votre@email.fr

# ── Analytics (Plausible ou Umami) ───────────────────────────
# Optionnel — ne se charge qu'en production si défini
NEXT_PUBLIC_ANALYTICS_DOMAIN=votre-domaine.fr
NEXT_PUBLIC_ANALYTICS_SCRIPT=https://plausible.io/js/script.js
